  405|    449|    fn codegen_binary_logical_or(&self, left: &Expression, right: &Expression) -> LLVMValue {
  406|       |        // NOTE: Logical OR is a short-circuiting operator.
  407|       |        // This means that if the left operand is true, the right operand is not
  408|       |        // evaluated.
  409|    449|        let left_value = self.codegen_expression(left);
  410|       |
  411|       |        // Check if left_value is not zero (true)
  412|    449|        let zero = self.const_int(0);
  413|    449|        let left_is_true = self.builder.integer_not_equal(left_value, zero);
  414|       |
  415|       |        // Get the current function to create a new basic blocks
  416|    449|        let function = self.get_current_function();
  417|       |
  418|       |        // Create basic blocks for the right-hand side and the true case
  419|    449|        let rhs_basic_block = self.context.create_basic_block("lor.rhs");
  420|    449|        let true_basic_block = self.context.create_basic_block("lor.true");
  421|    449|        let false_basic_block = self.context.create_basic_block("lor.false");
  422|    449|        let end_basic_block = self.context.create_basic_block("lor.end");
  423|       |
  424|       |        // Conditionally branch to the true case or the right-hand side if left is false
  425|    449|        self.builder
  426|    449|            .conditional_branch(left_is_true, true_basic_block, rhs_basic_block);
  427|       |
  428|       |        // Build the rhs basic block
  429|    449|        self.builder.position_at_end(rhs_basic_block);
  430|    449|        function.append_existing_basic_block(rhs_basic_block);
  431|       |
  432|    449|        let right_value = self.codegen_expression(right);
  433|       |
  434|       |        // Check if right_value is not zero
  435|    449|        let right_is_true = self.builder.integer_not_equal(right_value, zero);
  436|       |
