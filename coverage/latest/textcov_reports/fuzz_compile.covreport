  229|  3.19k|                self.builder.unreachable();
  230|  3.19k|            }
  231|    130|        }
  232|       |
  233|       |        // Verify generated function and when fuzzing abort on failure
  234|       |        #[cfg(not(fuzzing))]
  235|       |        if !verify_function(
  236|       |            llvm_function,
  237|       |            LLVMVerifierFailureAction::LLVMPrintMessageAction,
  238|       |        ) {
  239|       |            println!("Function verification failed");
  240|       |            return false;
  241|       |        }
  242|       |        #[cfg(fuzzing)]
  243|  3.48k|        let _ = verify_function(
  244|  3.48k|            llvm_function,
  245|  3.48k|            LLVMVerifierFailureAction::LLVMAbortProcessAction,
  246|  3.48k|        );
  247|       |
  248|  3.48k|        true
  249|  3.48k|    }
