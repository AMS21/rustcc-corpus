  201|  29.4k|        for statement in &function.body {
  202|  26.4k|            if self.builder.has_insert_block_terminator() {
  203|       |                // if the current block has a terminator, don't generate anything since it's
  204|       |                // unreachable
  205|       |                // TODO: Warn about unreachable code
  206|     78|                break;
  207|  26.4k|            }
  208|       |
  209|  26.4k|            match statement {
  210|  23.8k|                BlockItem::Statement(statement) => self.codegen_statement(statement),
  211|  2.55k|                BlockItem::Declaration(declaration) => {
  212|  2.55k|                    self.codegen_declaration(declaration);
  213|  2.55k|                }
  214|       |            }
  215|       |        }
  216|       |
  217|       |        // Check if the last block has a terminator
  218|       |        #[expect(clippy::expect_used)]
  219|  3.03k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  3.03k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  2.93k|            if function.name == "main" {
  224|     55|                // If main is missing a terminator add return 0
  225|     55|                let zero = self.const_int(0);
  226|     55|                self.builder.ret(zero);
  227|  2.88k|            } else {
  228|  2.88k|                // For all other functions add unreachable
  229|  2.88k|                self.builder.unreachable();
  230|  2.88k|            }
  231|     96|        }
  232|       |
  233|       |        // Verify generated function and when fuzzing abort on failure
  234|       |        #[cfg(not(fuzzing))]
  235|       |        if !verify_function(
  236|       |            llvm_function,
  237|       |            LLVMVerifierFailureAction::LLVMPrintMessageAction,
  238|       |        ) {
  239|       |            println!("Function verification failed");
  240|       |            return false;
  241|       |        }
  242|       |        #[cfg(fuzzing)]
  243|  3.03k|        let _ = verify_function(
  244|  3.03k|            llvm_function,
  245|  3.03k|            LLVMVerifierFailureAction::LLVMAbortProcessAction,
  246|  3.03k|        );
  247|       |
  248|  3.03k|        true
  249|  3.03k|    }
