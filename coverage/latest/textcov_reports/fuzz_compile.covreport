  458|  19.4k|        let right_is_true = self.builder.integer_not_equal(right_value, zero);
  459|       |
  460|       |        // Branch to the true or false basic block based on right_is_false
  461|  19.4k|        self.builder
  462|  19.4k|            .conditional_branch(right_is_true, true_basic_block, false_basic_block);
  463|       |
  464|       |        // Build the true basic block
  465|  19.4k|        self.builder.position_at_end(true_basic_block);
  466|  19.4k|        self.builder.unconditional_branch(end_basic_block);
  467|       |
  468|       |        // Build the false basic block
  469|  19.4k|        self.builder.position_at_end(false_basic_block);
  470|  19.4k|        self.builder.unconditional_branch(end_basic_block);
  471|       |
  472|       |        // Build the end merger basic block
  473|  19.4k|        self.builder.position_at_end(end_basic_block);
  474|       |
  475|       |        // Create a PHI node to merge the results
  476|  19.4k|        let phi = self.builder.phi(self.int32_type(), "land.phi");
  477|  19.4k|        let true_value = self.const_int(1);
  478|  19.4k|        let false_value = self.const_int(0);
  479|       |
  480|       |        // Add incoming values to the PHI node
  481|  19.4k|        phi.add_incoming(
  482|  19.4k|            &[true_value, false_value],
  483|  19.4k|            &[true_basic_block, false_basic_block],
