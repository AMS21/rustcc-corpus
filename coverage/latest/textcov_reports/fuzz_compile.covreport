  772|    427|    fn codegen_unary_prefix_decrement(&self, expression: &Expression) -> LLVMValue {
  773|       |        // The operand of a prefix decrement must be an l-value.
  774|    427|        let Some(name) = expression.as_variable_name() else {
  775|      0|            panic!("operand of prefix decrement must be an l-value");
  776|       |        };
  777|       |
  778|       |        // First load the current value of the variable
  779|    427|        let current_value = self.load_variable(name);
  780|       |
  781|       |        // Then subtract 1 from it
  782|    427|        let one = self.const_int(1);
  783|    427|        let new_value = self.builder.subtract(current_value, one);
  784|       |
  785|       |        // Then store the new value back in the variable
  786|    427|        self.store_variable(name, new_value);
  787|       |
  788|       |        // The value of a prefix decrement expression is the new value, so return it
  789|    427|        new_value
  790|    427|    }
