  219|  8.30k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  8.30k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  8.25k|            if function.name == "main" {
  224|     57|                // If main is missing a terminator add return 0
  225|     57|                let zero = self.const_int(0);
  226|     57|                self.builder.ret(zero);
  227|  8.20k|            } else {
