  219|  2.96k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  2.96k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  2.89k|            if function.name == "main" {
  224|    121|                // If main is missing a terminator add return 0
  225|    121|                let zero = self.const_int(0);
  226|    121|                self.builder.ret(zero);
  227|  2.77k|            } else {
