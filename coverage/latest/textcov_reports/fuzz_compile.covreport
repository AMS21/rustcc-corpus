  203|       |                // if the current block has a terminator, don't generate anything since it's
  204|       |                // unreachable
  205|       |                // TODO: Warn about unreachable code
  206|     67|                break;
  207|  14.7k|            }
  208|       |
  209|  14.7k|            match statement {
  210|  11.5k|                BlockItem::Statement(statement) => self.codegen_statement(statement),
  211|  3.24k|                BlockItem::Declaration(declaration) => {
  212|  3.24k|                    self.codegen_declaration(declaration);
  213|  3.24k|                }
  214|       |            }
  215|       |        }
  216|       |
  217|       |        // Check if the last block has a terminator
