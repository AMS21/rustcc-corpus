   55|      1|    pub fn new(file_path: &str) -> Result<Self, CodegenError> {
   56|      1|        let context = LLVMContext::new().ok_or(CodegenError::FailedContextCreation)?;
   57|      1|        let module = LLVMModule::new_in_context(file_path, &context)
   58|      1|            .ok_or(CodegenError::FailedModuleCreation)?;
   59|      1|        let builder =
   60|      1|            LLVMBuilder::new_in_context(&context).ok_or(CodegenError::FailedBuilderCreation)?;
   61|       |
   62|      1|        Ok(Self {
   63|      1|            builder,
   64|      1|            module,
   65|      1|            context,
   66|      1|            symbol_table: RefCell::new(FxHashMap::default()),
