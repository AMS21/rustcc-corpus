  219|  4.27k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  4.27k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  3.98k|            if function.name == "main" {
  224|    182|                // If main is missing a terminator add return 0
  225|    182|                let zero = self.const_int(0);
  226|    182|                self.builder.ret(zero);
  227|  3.80k|            } else {
