  203|       |                // if the current block has a terminator, don't generate anything since it's
  204|       |                // unreachable
  205|       |                // TODO: Warn about unreachable code
  206|     67|                break;
  207|  14.8k|            }
  208|       |
  209|  14.8k|            match statement {
  210|  11.4k|                BlockItem::Statement(statement) => self.codegen_statement(statement),
  211|  3.36k|                BlockItem::Declaration(declaration) => {
  212|  3.36k|                    self.codegen_declaration(declaration);
  213|  3.36k|                }
  214|       |            }
  215|       |        }
  216|       |
  217|       |        // Check if the last block has a terminator
  218|       |        #[expect(clippy::expect_used)]
  219|  2.82k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  2.82k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  2.74k|            if function.name == "main" {
  224|    193|                // If main is missing a terminator add return 0
  225|    193|                let zero = self.const_int(0);
  226|    193|                self.builder.ret(zero);
  227|  2.55k|            } else {
  228|  2.55k|                // For all other functions add unreachable
  229|  2.55k|                self.builder.unreachable();
  230|  2.55k|            }
  231|     82|        }
  232|       |
  233|       |        // Verify generated function and when fuzzing abort on failure
  234|       |        #[cfg(not(fuzzing))]
  235|       |        if !verify_function(
  236|       |            llvm_function,
  237|       |            LLVMVerifierFailureAction::LLVMPrintMessageAction,
  238|       |        ) {
  239|       |            println!("Function verification failed");
  240|       |            return false;
  241|       |        }
  242|       |        #[cfg(fuzzing)]
  243|  2.82k|        let _ = verify_function(
  244|  2.82k|            llvm_function,
  245|  2.82k|            LLVMVerifierFailureAction::LLVMAbortProcessAction,
  246|  2.82k|        );
  247|       |
  248|  2.82k|        true
  249|  2.82k|    }
