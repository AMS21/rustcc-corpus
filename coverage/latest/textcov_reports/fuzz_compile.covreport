  186|  5.87k|    fn codegen_function(&self, function: &FunctionDefinition) -> bool {
  187|       |        // Clear the symbol table for the new function scope
  188|  5.87k|        self.symbol_table.borrow_mut().clear();
  189|       |
  190|       |        // Create the function type
  191|  5.87k|        let function_type = function_type(self.int32_type());
  192|       |
  193|       |        // Create the function
  194|  5.87k|        let llvm_function = self.function(&function.name, function_type);
  195|       |
  196|       |        // Create a basic block in the function and set our builder to generate
  197|       |        // code in it.
  198|  5.87k|        self.function_basic_block("entry", llvm_function);
  199|       |
  200|       |        // Codegen the function body
  201|  59.2k|        for statement in &function.body {
  202|  53.4k|            if self.builder.has_insert_block_terminator() {
  203|       |                // if the current block has a terminator, don't generate anything since it's
  204|       |                // unreachable
  205|       |                // TODO: Warn about unreachable code
  206|     54|                break;
  207|  53.4k|            }
  208|       |
  209|  53.4k|            match statement {
  210|  48.2k|                BlockItem::Statement(statement) => self.codegen_statement(statement),
  211|  5.19k|                BlockItem::Declaration(declaration) => {
  212|  5.19k|                    self.codegen_declaration(declaration);
  213|  5.19k|                }
  214|       |            }
  215|       |        }
  216|       |
  217|       |        // Check if the last block has a terminator
  218|       |        #[expect(clippy::expect_used)]
  219|  5.87k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  5.87k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  5.80k|            if function.name == "main" {
  224|     47|                // If main is missing a terminator add return 0
  225|     47|                let zero = self.const_int(0);
  226|     47|                self.builder.ret(zero);
  227|  5.75k|            } else {
  228|  5.75k|                // For all other functions add unreachable
  229|  5.75k|                self.builder.unreachable();
  230|  5.75k|            }
  231|     68|        }
  232|       |
  233|       |        // Verify generated function and when fuzzing abort on failure
  234|       |        #[cfg(not(fuzzing))]
  235|       |        if !verify_function(
  236|       |            llvm_function,
  237|       |            LLVMVerifierFailureAction::LLVMPrintMessageAction,
  238|       |        ) {
  239|       |            println!("Function verification failed");
  240|       |            return false;
  241|       |        }
  242|       |        #[cfg(fuzzing)]
  243|  5.87k|        let _ = verify_function(
  244|  5.87k|            llvm_function,
  245|  5.87k|            LLVMVerifierFailureAction::LLVMAbortProcessAction,
  246|  5.87k|        );
  247|       |
  248|  5.87k|        true
  249|  5.87k|    }
