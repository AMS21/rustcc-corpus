  219|  4.16k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  4.16k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  4.01k|            if function.name == "main" {
  224|    161|                // If main is missing a terminator add return 0
  225|    161|                let zero = self.const_int(0);
  226|    161|                self.builder.ret(zero);
  227|  3.85k|            } else {
