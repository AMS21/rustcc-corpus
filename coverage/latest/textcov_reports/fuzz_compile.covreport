  202|  45.4k|            if self.builder.has_insert_block_terminator() {
  203|       |                // if the current block has a terminator, don't generate anything since it's
  204|       |                // unreachable
  205|       |                // TODO: Warn about unreachable code
  206|     80|                break;
  207|  45.3k|            }
  208|       |
  209|  45.3k|            match statement {
  210|  41.5k|                BlockItem::Statement(statement) => self.codegen_statement(statement),
  211|  3.85k|                BlockItem::Declaration(declaration) => {
  212|  3.85k|                    self.codegen_declaration(declaration);
  213|  3.85k|                }
  214|       |            }
  215|       |        }
  216|       |
  217|       |        // Check if the last block has a terminator
  218|       |        #[expect(clippy::expect_used)]
  219|  4.66k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  4.66k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  4.57k|            if function.name == "main" {
  224|     60|                // If main is missing a terminator add return 0
  225|     60|                let zero = self.const_int(0);
  226|     60|                self.builder.ret(zero);
  227|  4.51k|            } else {
  228|  4.51k|                // For all other functions add unreachable
  229|  4.51k|                self.builder.unreachable();
  230|  4.51k|            }
  231|     92|        }
  232|       |
  233|       |        // Verify generated function and when fuzzing abort on failure
  234|       |        #[cfg(not(fuzzing))]
  235|       |        if !verify_function(
  236|       |            llvm_function,
  237|       |            LLVMVerifierFailureAction::LLVMPrintMessageAction,
  238|       |        ) {
  239|       |            println!("Function verification failed");
  240|       |            return false;
  241|       |        }
  242|       |        #[cfg(fuzzing)]
  243|  4.66k|        let _ = verify_function(
  244|  4.66k|            llvm_function,
  245|  4.66k|            LLVMVerifierFailureAction::LLVMAbortProcessAction,
  246|  4.66k|        );
  247|       |
  248|  4.66k|        true
  249|  4.66k|    }
