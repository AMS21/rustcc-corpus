  202|  19.5k|            if self.builder.has_insert_block_terminator() {
  203|       |                // if the current block has a terminator, don't generate anything since it's
  204|       |                // unreachable
  205|       |                // TODO: Warn about unreachable code
  206|    115|                break;
  207|  19.3k|            }
  208|       |
  209|  19.3k|            match statement {
  210|  15.4k|                BlockItem::Statement(statement) => self.codegen_statement(statement),
  211|  3.89k|                BlockItem::Declaration(declaration) => {
  212|  3.89k|                    self.codegen_declaration(declaration);
  213|  3.89k|                }
  214|       |            }
  215|       |        }
  216|       |
  217|       |        // Check if the last block has a terminator
  218|       |        #[expect(clippy::expect_used)]
  219|  3.48k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  3.48k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  3.35k|            if function.name == "main" {
  224|    161|                // If main is missing a terminator add return 0
  225|    161|                let zero = self.const_int(0);
  226|    161|                self.builder.ret(zero);
  227|  3.19k|            } else {
