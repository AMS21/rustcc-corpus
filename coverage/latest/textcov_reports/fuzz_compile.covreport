  233|       |        // Verify generated function and when fuzzing abort on failure
  234|       |        #[cfg(not(fuzzing))]
  235|       |        if !verify_function(
  236|       |            llvm_function,
  237|       |            LLVMVerifierFailureAction::LLVMPrintMessageAction,
  238|       |        ) {
  239|       |            println!("Function verification failed");
  240|       |            return false;
  241|       |        }
  242|       |        #[cfg(fuzzing)]
  243|      1|        let _ = verify_function(
  244|      1|            llvm_function,
  245|      1|            LLVMVerifierFailureAction::LLVMAbortProcessAction,
  246|      1|        );
  247|       |
  248|      1|        true
