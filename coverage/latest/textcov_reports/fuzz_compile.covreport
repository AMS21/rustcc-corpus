  211|  1.20k|                BlockItem::Declaration(declaration) => {
  212|  1.20k|                    self.codegen_declaration(declaration);
  213|  1.20k|                }
  214|       |            }
  215|       |        }
  216|       |
  217|       |        // Check if the last block has a terminator
  218|       |        #[expect(clippy::expect_used)]
  219|  1.35k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  1.35k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  1.27k|            if function.name == "main" {
  224|     35|                // If main is missing a terminator add return 0
  225|     35|                let zero = self.const_int(0);
  226|     35|                self.builder.ret(zero);
  227|  1.23k|            } else {
