  466|  19.2k|        self.builder.unconditional_branch(end_basic_block);
  467|       |
  468|       |        // Build the false basic block
  469|  19.2k|        self.builder.position_at_end(false_basic_block);
  470|  19.2k|        self.builder.unconditional_branch(end_basic_block);
  471|       |
  472|       |        // Build the end merger basic block
  473|  19.2k|        self.builder.position_at_end(end_basic_block);
  474|       |
  475|       |        // Create a PHI node to merge the results
  476|  19.2k|        let phi = self.builder.phi(self.int32_type(), "land.phi");
  477|  19.2k|        let true_value = self.const_int(1);
  478|  19.2k|        let false_value = self.const_int(0);
  479|       |
  480|       |        // Add incoming values to the PHI node
  481|  19.2k|        phi.add_incoming(
