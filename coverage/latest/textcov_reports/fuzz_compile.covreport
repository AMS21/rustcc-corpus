  229|  1.23k|                self.builder.unreachable();
  230|  1.23k|            }
  231|     77|        }
  232|       |
  233|       |        // Verify generated function and when fuzzing abort on failure
  234|       |        #[cfg(not(fuzzing))]
  235|       |        if !verify_function(
  236|       |            llvm_function,
  237|       |            LLVMVerifierFailureAction::LLVMPrintMessageAction,
  238|       |        ) {
  239|       |            println!("Function verification failed");
  240|       |            return false;
  241|       |        }
  242|       |        #[cfg(fuzzing)]
  243|  1.35k|        let _ = verify_function(
  244|  1.35k|            llvm_function,
  245|  1.35k|            LLVMVerifierFailureAction::LLVMAbortProcessAction,
  246|  1.35k|        );
  247|       |
