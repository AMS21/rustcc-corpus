  186|  4.01k|    fn codegen_function(&self, function: &FunctionDefinition) -> bool {
  187|       |        // Clear the symbol table for the new function scope
  188|  4.01k|        self.symbol_table.borrow_mut().clear();
  189|       |
  190|       |        // Create the function type
  191|  4.01k|        let function_type = function_type(self.int32_type());
  192|       |
  193|       |        // Create the function
  194|  4.01k|        let llvm_function = self.function(&function.name, function_type);
  195|       |
  196|       |        // Create a basic block in the function and set our builder to generate
  197|       |        // code in it.
  198|  4.01k|        self.function_basic_block("entry", llvm_function);
  199|       |
  200|       |        // Codegen the function body
  201|  32.8k|        for statement in &function.body {
  202|  28.9k|            if self.builder.has_insert_block_terminator() {
  203|       |                // if the current block has a terminator, don't generate anything since it's
  204|       |                // unreachable
  205|       |                // TODO: Warn about unreachable code
  206|    111|                break;
  207|  28.8k|            }
  208|       |
  209|  28.8k|            match statement {
  210|  25.1k|                BlockItem::Statement(statement) => self.codegen_statement(statement),
  211|  3.74k|                BlockItem::Declaration(declaration) => {
  212|  3.74k|                    self.codegen_declaration(declaration);
  213|  3.74k|                }
  214|       |            }
  215|       |        }
  216|       |
  217|       |        // Check if the last block has a terminator
  218|       |        #[expect(clippy::expect_used)]
  219|  4.01k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  4.01k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  3.87k|            if function.name == "main" {
  224|    264|                // If main is missing a terminator add return 0
  225|    264|                let zero = self.const_int(0);
  226|    264|                self.builder.ret(zero);
  227|  3.60k|            } else {
  228|  3.60k|                // For all other functions add unreachable
  229|  3.60k|                self.builder.unreachable();
  230|  3.60k|            }
  231|    140|        }
  232|       |
  233|       |        // Verify generated function and when fuzzing abort on failure
  234|       |        #[cfg(not(fuzzing))]
  235|       |        if !verify_function(
  236|       |            llvm_function,
  237|       |            LLVMVerifierFailureAction::LLVMPrintMessageAction,
  238|       |        ) {
  239|       |            println!("Function verification failed");
  240|       |            return false;
  241|       |        }
  242|       |        #[cfg(fuzzing)]
  243|  4.01k|        let _ = verify_function(
  244|  4.01k|            llvm_function,
  245|  4.01k|            LLVMVerifierFailureAction::LLVMAbortProcessAction,
  246|  4.01k|        );
  247|       |
  248|  4.01k|        true
  249|  4.01k|    }
