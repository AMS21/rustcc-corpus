  201|  25.4k|        for statement in &function.body {
  202|  22.9k|            if self.builder.has_insert_block_terminator() {
  203|       |                // if the current block has a terminator, don't generate anything since it's
  204|       |                // unreachable
  205|       |                // TODO: Warn about unreachable code
  206|    113|                break;
  207|  22.7k|            }
  208|       |
  209|  22.7k|            match statement {
  210|  20.1k|                BlockItem::Statement(statement) => self.codegen_statement(statement),
  211|  2.61k|                BlockItem::Declaration(declaration) => {
  212|  2.61k|                    self.codegen_declaration(declaration);
  213|  2.61k|                }
  214|       |            }
  215|       |        }
  216|       |
  217|       |        // Check if the last block has a terminator
  218|       |        #[expect(clippy::expect_used)]
  219|  2.66k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  2.66k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  2.54k|            if function.name == "main" {
  224|     96|                // If main is missing a terminator add return 0
  225|     96|                let zero = self.const_int(0);
  226|     96|                self.builder.ret(zero);
  227|  2.44k|            } else {
  228|  2.44k|                // For all other functions add unreachable
  229|  2.44k|                self.builder.unreachable();
  230|  2.44k|            }
  231|    122|        }
  232|       |
  233|       |        // Verify generated function and when fuzzing abort on failure
  234|       |        #[cfg(not(fuzzing))]
  235|       |        if !verify_function(
  236|       |            llvm_function,
  237|       |            LLVMVerifierFailureAction::LLVMPrintMessageAction,
  238|       |        ) {
  239|       |            println!("Function verification failed");
  240|       |            return false;
  241|       |        }
  242|       |        #[cfg(fuzzing)]
  243|  2.66k|        let _ = verify_function(
  244|  2.66k|            llvm_function,
  245|  2.66k|            LLVMVerifierFailureAction::LLVMAbortProcessAction,
  246|  2.66k|        );
  247|       |
  248|  2.66k|        true
  249|  2.66k|    }
