  458|  28.4k|        let right_is_true = self.builder.integer_not_equal(right_value, zero);
  459|       |
  460|       |        // Branch to the true or false basic block based on right_is_false
  461|  28.4k|        self.builder
  462|  28.4k|            .conditional_branch(right_is_true, true_basic_block, false_basic_block);
  463|       |
  464|       |        // Build the true basic block
  465|  28.4k|        self.builder.position_at_end(true_basic_block);
  466|  28.4k|        self.builder.unconditional_branch(end_basic_block);
  467|       |
