  219|  2.95k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  2.95k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  2.87k|            if function.name == "main" {
  224|    159|                // If main is missing a terminator add return 0
  225|    159|                let zero = self.const_int(0);
  226|    159|                self.builder.ret(zero);
  227|  2.71k|            } else {
  228|  2.71k|                // For all other functions add unreachable
  229|  2.71k|                self.builder.unreachable();
  230|  2.71k|            }
  231|     79|        }
  232|       |
  233|       |        // Verify generated function and when fuzzing abort on failure
  234|       |        #[cfg(not(fuzzing))]
  235|       |        if !verify_function(
  236|       |            llvm_function,
  237|       |            LLVMVerifierFailureAction::LLVMPrintMessageAction,
  238|       |        ) {
  239|       |            println!("Function verification failed");
  240|       |            return false;
  241|       |        }
  242|       |        #[cfg(fuzzing)]
  243|  2.95k|        let _ = verify_function(
  244|  2.95k|            llvm_function,
  245|  2.95k|            LLVMVerifierFailureAction::LLVMAbortProcessAction,
  246|  2.95k|        );
  247|       |
