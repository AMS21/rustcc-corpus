  186|  2.77k|    fn codegen_function(&self, function: &FunctionDefinition) -> bool {
  187|       |        // Clear the symbol table for the new function scope
  188|  2.77k|        self.symbol_table.borrow_mut().clear();
  189|       |
  190|       |        // Create the function type
  191|  2.77k|        let function_type = function_type(self.int32_type());
  192|       |
  193|       |        // Create the function
  194|  2.77k|        let llvm_function = self.function(&function.name, function_type);
  195|       |
  196|       |        // Create a basic block in the function and set our builder to generate
  197|       |        // code in it.
  198|  2.77k|        self.function_basic_block("entry", llvm_function);
  199|       |
  200|       |        // Codegen the function body
  201|  20.0k|        for statement in &function.body {
  202|  17.5k|            if self.builder.has_insert_block_terminator() {
  203|       |                // if the current block has a terminator, don't generate anything since it's
  204|       |                // unreachable
  205|       |                // TODO: Warn about unreachable code
  206|    195|                break;
  207|  17.3k|            }
  208|       |
  209|  17.3k|            match statement {
  210|  14.1k|                BlockItem::Statement(statement) => self.codegen_statement(statement),
  211|  3.17k|                BlockItem::Declaration(declaration) => {
  212|  3.17k|                    self.codegen_declaration(declaration);
  213|  3.17k|                }
  214|       |            }
  215|       |        }
  216|       |
  217|       |        // Check if the last block has a terminator
  218|       |        #[expect(clippy::expect_used)]
  219|  2.77k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  2.77k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  2.56k|            if function.name == "main" {
  224|    149|                // If main is missing a terminator add return 0
  225|    149|                let zero = self.const_int(0);
  226|    149|                self.builder.ret(zero);
  227|  2.41k|            } else {
  228|  2.41k|                // For all other functions add unreachable
  229|  2.41k|                self.builder.unreachable();
  230|  2.41k|            }
  231|    207|        }
  232|       |
  233|       |        // Verify generated function and when fuzzing abort on failure
  234|       |        #[cfg(not(fuzzing))]
  235|       |        if !verify_function(
  236|       |            llvm_function,
  237|       |            LLVMVerifierFailureAction::LLVMPrintMessageAction,
  238|       |        ) {
  239|       |            println!("Function verification failed");
  240|       |            return false;
  241|       |        }
  242|       |        #[cfg(fuzzing)]
  243|  2.77k|        let _ = verify_function(
  244|  2.77k|            llvm_function,
  245|  2.77k|            LLVMVerifierFailureAction::LLVMAbortProcessAction,
  246|  2.77k|        );
  247|       |
  248|  2.77k|        true
  249|  2.77k|    }
