  222|       |            // TODO: What about void function
  223|      1|            if function.name == "main" {
  224|      0|                // If main is missing a terminator add return 0
  225|      0|                let zero = self.const_int(0);
  226|      0|                self.builder.ret(zero);
  227|      1|            } else {
  228|      1|                // For all other functions add unreachable
  229|      1|                self.builder.unreachable();
  230|      1|            }
  231|      0|        }
