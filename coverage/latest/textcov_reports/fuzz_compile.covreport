  219|  3.14k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  3.14k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  3.05k|            if function.name == "main" {
  224|    224|                // If main is missing a terminator add return 0
