  219|  2.90k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  2.90k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  2.80k|            if function.name == "main" {
  224|    200|                // If main is missing a terminator add return 0
  225|    200|                let zero = self.const_int(0);
  226|    200|                self.builder.ret(zero);
  227|  2.60k|            } else {
