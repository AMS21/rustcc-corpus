  459|       |
  460|       |        // Branch to the true or false basic block based on right_is_false
  461|  19.2k|        self.builder
  462|  19.2k|            .conditional_branch(right_is_true, true_basic_block, false_basic_block);
  463|       |
  464|       |        // Build the true basic block
