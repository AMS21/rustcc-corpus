  211|  5.10k|                BlockItem::Declaration(declaration) => {
  212|  5.10k|                    self.codegen_declaration(declaration);
  213|  5.10k|                }
  214|       |            }
  215|       |        }
  216|       |
  217|       |        // Check if the last block has a terminator
  218|       |        #[expect(clippy::expect_used)]
  219|  4.95k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  4.95k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  4.80k|            if function.name == "main" {
  224|    292|                // If main is missing a terminator add return 0
  225|    292|                let zero = self.const_int(0);
  226|    292|                self.builder.ret(zero);
  227|  4.51k|            } else {
