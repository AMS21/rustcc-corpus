_RNvMs0_Cs3BBBiRK415A_14rustcc_codegenNtB5_7Codegen30codegen_unary_prefix_decrement:
  772|    388|    fn codegen_unary_prefix_decrement(&self, expression: &Expression) -> LLVMValue {
  773|       |        // The operand of a prefix decrement must be an l-value.
  774|    388|        let Some(name) = expression.as_variable_name() else {
  775|      0|            panic!("operand of prefix decrement must be an l-value");
  776|       |        };
  777|       |
  778|       |        // First load the current value of the variable
  779|    388|        let current_value = self.load_variable(name);
  780|       |
  781|       |        // Then subtract 1 from it
  782|    388|        let one = self.const_int(1);
  783|    388|        let new_value = self.builder.subtract(current_value, one);
  784|       |
  785|       |        // Then store the new value back in the variable
  786|    388|        self.store_variable(name, new_value);
  787|       |
  788|       |        // The value of a prefix decrement expression is the new value, so return it
  789|    388|        new_value
  790|    388|    }
_RNvMs0_Cs3BBBiRK415A_14rustcc_codegenNtB5_7Codegen30codegen_unary_prefix_increment:
  751|    204|    fn codegen_unary_prefix_increment(&self, expression: &Expression) -> LLVMValue {
  752|       |        // The operand of a prefix increment must be an l-value.
  753|    204|        let Some(name) = expression.as_variable_name() else {
  754|      0|            panic!("operand of prefix increment must be an l-value");
  755|       |        };
  756|       |
  757|       |        // First load the current value of the variable
  758|    204|        let current_value = self.load_variable(name);
  759|       |
  760|       |        // Then add 1 to it
  761|    204|        let one = self.const_int(1);
  762|    204|        let new_value = self.builder.add(current_value, one);
  763|       |
  764|       |        // Then store the new value back in the variable
