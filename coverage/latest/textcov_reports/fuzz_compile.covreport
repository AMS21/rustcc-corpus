  203|       |                // if the current block has a terminator, don't generate anything since it's
  204|       |                // unreachable
  205|       |                // TODO: Warn about unreachable code
  206|     15|                break;
  207|  51.5k|            }
  208|       |
  209|  51.5k|            match statement {
  210|  48.0k|                BlockItem::Statement(statement) => self.codegen_statement(statement),
  211|  3.42k|                BlockItem::Declaration(declaration) => {
  212|  3.42k|                    self.codegen_declaration(declaration);
  213|  3.42k|                }
  214|       |            }
  215|       |        }
  216|       |
  217|       |        // Check if the last block has a terminator
