  561|  1.40k|    fn codegen_binary_assignment(&self, left: &Expression, right_value: LLVMValue) -> LLVMValue {
  562|       |        // The left-hand side of an assignment must be an l-value.
  563|  1.40k|        let Some(name) = left.as_variable_name() else {
  564|      0|            panic!("left-hand side of assignment must be an l-value");
  565|       |        };
  566|       |
  567|       |        // Store the right-hand side value into the existing variable
  568|  1.40k|        self.store_variable(name, right_value);
