  211|  4.85k|                BlockItem::Declaration(declaration) => {
  212|  4.85k|                    self.codegen_declaration(declaration);
  213|  4.85k|                }
  214|       |            }
  215|       |        }
  216|       |
  217|       |        // Check if the last block has a terminator
