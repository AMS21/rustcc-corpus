  211|  1.17k|                BlockItem::Declaration(declaration) => {
  212|  1.17k|                    self.codegen_declaration(declaration);
  213|  1.17k|                }
  214|       |            }
  215|       |        }
  216|       |
  217|       |        // Check if the last block has a terminator
  218|       |        #[expect(clippy::expect_used)]
  219|  1.40k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  1.40k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  1.36k|            if function.name == "main" {
  224|     35|                // If main is missing a terminator add return 0
  225|     35|                let zero = self.const_int(0);
  226|     35|                self.builder.ret(zero);
  227|  1.32k|            } else {
  228|  1.32k|                // For all other functions add unreachable
  229|  1.32k|                self.builder.unreachable();
  230|  1.32k|            }
  231|     44|        }
  232|       |
  233|       |        // Verify generated function and when fuzzing abort on failure
  234|       |        #[cfg(not(fuzzing))]
  235|       |        if !verify_function(
  236|       |            llvm_function,
  237|       |            LLVMVerifierFailureAction::LLVMPrintMessageAction,
  238|       |        ) {
  239|       |            println!("Function verification failed");
  240|       |            return false;
  241|       |        }
  242|       |        #[cfg(fuzzing)]
  243|  1.40k|        let _ = verify_function(
  244|  1.40k|            llvm_function,
  245|  1.40k|            LLVMVerifierFailureAction::LLVMAbortProcessAction,
  246|  1.40k|        );
  247|       |
  248|  1.40k|        true
  249|  1.40k|    }
