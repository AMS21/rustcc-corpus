  186|  3.03k|    fn codegen_function(&self, function: &FunctionDefinition) -> bool {
  187|       |        // Clear the symbol table for the new function scope
  188|  3.03k|        self.symbol_table.borrow_mut().clear();
  189|       |
  190|       |        // Create the function type
  191|  3.03k|        let function_type = function_type(self.int32_type());
  192|       |
  193|       |        // Create the function
  194|  3.03k|        let llvm_function = self.function(&function.name, function_type);
  195|       |
  196|       |        // Create a basic block in the function and set our builder to generate
  197|       |        // code in it.
  198|  3.03k|        self.function_basic_block("entry", llvm_function);
  199|       |
