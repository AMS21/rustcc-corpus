  186|  1.26k|    fn codegen_function(&self, function: &FunctionDefinition) -> bool {
  187|       |        // Clear the symbol table for the new function scope
  188|  1.26k|        self.symbol_table.borrow_mut().clear();
  189|       |
  190|       |        // Create the function type
  191|  1.26k|        let function_type = function_type(self.int32_type());
  192|       |
  193|       |        // Create the function
  194|  1.26k|        let llvm_function = self.function(&function.name, function_type);
  195|       |
  196|       |        // Create a basic block in the function and set our builder to generate
  197|       |        // code in it.
  198|  1.26k|        self.function_basic_block("entry", llvm_function);
  199|       |
  200|       |        // Codegen the function body
