  470|  28.4k|        self.builder.unconditional_branch(end_basic_block);
  471|       |
  472|       |        // Build the end merger basic block
  473|  28.4k|        self.builder.position_at_end(end_basic_block);
  474|       |
  475|       |        // Create a PHI node to merge the results
  476|  28.4k|        let phi = self.builder.phi(self.int32_type(), "land.phi");
  477|  28.4k|        let true_value = self.const_int(1);
  478|  28.4k|        let false_value = self.const_int(0);
  479|       |
  480|       |        // Add incoming values to the PHI node
  481|  28.4k|        phi.add_incoming(
  482|  28.4k|            &[true_value, false_value],
  483|  28.4k|            &[true_basic_block, false_basic_block],
  484|       |        );
  485|       |
