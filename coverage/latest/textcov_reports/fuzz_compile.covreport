  229|  4.51k|                self.builder.unreachable();
  230|  4.51k|            }
  231|    155|        }
  232|       |
  233|       |        // Verify generated function and when fuzzing abort on failure
  234|       |        #[cfg(not(fuzzing))]
  235|       |        if !verify_function(
  236|       |            llvm_function,
  237|       |            LLVMVerifierFailureAction::LLVMPrintMessageAction,
  238|       |        ) {
  239|       |            println!("Function verification failed");
  240|       |            return false;
  241|       |        }
  242|       |        #[cfg(fuzzing)]
  243|  4.95k|        let _ = verify_function(
  244|  4.95k|            llvm_function,
  245|  4.95k|            LLVMVerifierFailureAction::LLVMAbortProcessAction,
  246|  4.95k|        );
  247|       |
  248|  4.95k|        true
  249|  4.95k|    }
