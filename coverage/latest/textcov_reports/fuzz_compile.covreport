  202|  9.24k|            if self.builder.has_insert_block_terminator() {
  203|       |                // if the current block has a terminator, don't generate anything since it's
  204|       |                // unreachable
  205|       |                // TODO: Warn about unreachable code
  206|     35|                break;
  207|  9.21k|            }
  208|       |
  209|  9.21k|            match statement {
  210|  8.24k|                BlockItem::Statement(statement) => self.codegen_statement(statement),
  211|    967|                BlockItem::Declaration(declaration) => {
  212|    967|                    self.codegen_declaration(declaration);
  213|    967|                }
  214|       |            }
  215|       |        }
  216|       |
  217|       |        // Check if the last block has a terminator
  218|       |        #[expect(clippy::expect_used)]
  219|  1.26k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  1.26k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  1.21k|            if function.name == "main" {
  224|     20|                // If main is missing a terminator add return 0
  225|     20|                let zero = self.const_int(0);
  226|     20|                self.builder.ret(zero);
  227|  1.19k|            } else {
  228|  1.19k|                // For all other functions add unreachable
  229|  1.19k|                self.builder.unreachable();
  230|  1.19k|            }
  231|     44|        }
  232|       |
  233|       |        // Verify generated function and when fuzzing abort on failure
  234|       |        #[cfg(not(fuzzing))]
  235|       |        if !verify_function(
  236|       |            llvm_function,
  237|       |            LLVMVerifierFailureAction::LLVMPrintMessageAction,
  238|       |        ) {
  239|       |            println!("Function verification failed");
  240|       |            return false;
  241|       |        }
  242|       |        #[cfg(fuzzing)]
  243|  1.26k|        let _ = verify_function(
  244|  1.26k|            llvm_function,
  245|  1.26k|            LLVMVerifierFailureAction::LLVMAbortProcessAction,
  246|  1.26k|        );
  247|       |
  248|  1.26k|        true
  249|  1.26k|    }
