  240|       |            return false;
  241|       |        }
  242|       |        #[cfg(fuzzing)]
  243|  4.49k|        let _ = verify_function(
  244|  4.49k|            llvm_function,
  245|  4.49k|            LLVMVerifierFailureAction::LLVMAbortProcessAction,
