  459|       |
  460|       |        // Branch to the true or false basic block based on right_is_false
  461|  21.0k|        self.builder
  462|  21.0k|            .conditional_branch(right_is_true, true_basic_block, false_basic_block);
  463|       |
  464|       |        // Build the true basic block
  465|  21.0k|        self.builder.position_at_end(true_basic_block);
  466|  21.0k|        self.builder.unconditional_branch(end_basic_block);
  467|       |
  468|       |        // Build the false basic block
