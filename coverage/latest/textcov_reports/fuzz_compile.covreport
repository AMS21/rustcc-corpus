  202|  26.6k|            if self.builder.has_insert_block_terminator() {
  203|       |                // if the current block has a terminator, don't generate anything since it's
  204|       |                // unreachable
  205|       |                // TODO: Warn about unreachable code
  206|    147|                break;
  207|  26.5k|            }
  208|       |
  209|  26.5k|            match statement {
  210|  22.2k|                BlockItem::Statement(statement) => self.codegen_statement(statement),
  211|  4.27k|                BlockItem::Declaration(declaration) => {
  212|  4.27k|                    self.codegen_declaration(declaration);
  213|  4.27k|                }
  214|       |            }
  215|       |        }
  216|       |
  217|       |        // Check if the last block has a terminator
  218|       |        #[expect(clippy::expect_used)]
  219|  4.33k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  4.33k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  4.16k|            if function.name == "main" {
  224|    335|                // If main is missing a terminator add return 0
  225|    335|                let zero = self.const_int(0);
  226|    335|                self.builder.ret(zero);
  227|  3.83k|            } else {
  228|  3.83k|                // For all other functions add unreachable
  229|  3.83k|                self.builder.unreachable();
  230|  3.83k|            }
  231|    166|        }
  232|       |
  233|       |        // Verify generated function and when fuzzing abort on failure
  234|       |        #[cfg(not(fuzzing))]
  235|       |        if !verify_function(
  236|       |            llvm_function,
  237|       |            LLVMVerifierFailureAction::LLVMPrintMessageAction,
  238|       |        ) {
  239|       |            println!("Function verification failed");
  240|       |            return false;
  241|       |        }
  242|       |        #[cfg(fuzzing)]
  243|  4.33k|        let _ = verify_function(
  244|  4.33k|            llvm_function,
  245|  4.33k|            LLVMVerifierFailureAction::LLVMAbortProcessAction,
  246|  4.33k|        );
  247|       |
  248|  4.33k|        true
  249|  4.33k|    }
