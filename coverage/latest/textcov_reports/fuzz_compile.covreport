_RNvMs0_Csa3tq7LJwGU2_14rustcc_codegenNtB5_7Codegen30codegen_unary_prefix_decrement:
  772|    347|    fn codegen_unary_prefix_decrement(&self, expression: &Expression) -> LLVMValue {
  773|       |        // The operand of a prefix decrement must be an l-value.
  774|    347|        let Some(name) = expression.as_variable_name() else {
  775|      0|            panic!("operand of prefix decrement must be an l-value");
  776|       |        };
  777|       |
  778|       |        // First load the current value of the variable
  779|    347|        let current_value = self.load_variable(name);
  780|       |
  781|       |        // Then subtract 1 from it
  782|    347|        let one = self.const_int(1);
  783|    347|        let new_value = self.builder.subtract(current_value, one);
  784|       |
  785|       |        // Then store the new value back in the variable
  786|    347|        self.store_variable(name, new_value);
  787|       |
  788|       |        // The value of a prefix decrement expression is the new value, so return it
  789|    347|        new_value
  790|    347|    }
_RNvMs0_Csa3tq7LJwGU2_14rustcc_codegenNtB5_7Codegen30codegen_unary_prefix_increment:
  751|    152|    fn codegen_unary_prefix_increment(&self, expression: &Expression) -> LLVMValue {
  752|       |        // The operand of a prefix increment must be an l-value.
  753|    152|        let Some(name) = expression.as_variable_name() else {
  754|      0|            panic!("operand of prefix increment must be an l-value");
  755|       |        };
  756|       |
  757|       |        // First load the current value of the variable
  758|    152|        let current_value = self.load_variable(name);
  759|       |
  760|       |        // Then add 1 to it
  761|    152|        let one = self.const_int(1);
