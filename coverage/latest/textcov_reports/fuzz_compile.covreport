  436|       |
  437|       |        // Get the current function to create a new basic blocks
  438|  19.2k|        let function = self.get_current_function();
  439|       |
  440|       |        // Create basic blocks for the right-hand side and the false case
  441|  19.2k|        let rhs_basic_block = self.context.create_basic_block("land.rhs");
  442|  19.2k|        let false_basic_block = self.context.create_basic_block("land.false");
  443|  19.2k|        let true_basic_block = self.context.create_basic_block("land.true");
