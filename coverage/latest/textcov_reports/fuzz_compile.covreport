_RNvMs0_Cs3o0P8Y3fg0l_14rustcc_codegenNtB5_7Codegen25codegen_binary_logical_or:
  494|    201|    fn codegen_binary_logical_or(&self, left: &Expression, right: &Expression) -> LLVMValue {
  495|       |        // NOTE: Logical OR is a short-circuiting operator.
  496|       |        // This means that if the left operand is true, the right operand is not
  497|       |        // evaluated.
  498|    201|        let left_value = self.codegen_expression(left);
  499|       |
  500|       |        // Check if left_value is not zero (true)
  501|    201|        let zero = self.const_int(0);
  502|    201|        let left_is_true = self.builder.integer_not_equal(left_value, zero);
  503|       |
  504|       |        // Get the current function to create a new basic blocks
  505|    201|        let function = self.get_current_function();
  506|       |
  507|       |        // Create basic blocks for the right-hand side and the true case
  508|    201|        let rhs_basic_block = self.context.create_basic_block("lor.rhs");
  509|    201|        let true_basic_block = self.context.create_basic_block("lor.true");
  510|    201|        let false_basic_block = self.context.create_basic_block("lor.false");
  511|    201|        let end_basic_block = self.context.create_basic_block("lor.end");
  512|       |
  513|       |        // Conditionally branch to the true case or the right-hand side if left is false
  514|    201|        self.builder
  515|    201|            .conditional_branch(left_is_true, true_basic_block, rhs_basic_block);
  516|       |
  517|       |        // Build the rhs basic block
  518|    201|        self.builder.position_at_end(rhs_basic_block);
  519|    201|        function.append_existing_basic_block(rhs_basic_block);
  520|       |
  521|    201|        let right_value = self.codegen_expression(right);
  522|       |
  523|       |        // Check if right_value is not zero
  524|    201|        let right_is_true = self.builder.integer_not_equal(right_value, zero);
  525|       |
  526|       |        // Branch to the true or false basic block based on right_is_true
  527|    201|        self.builder
  528|    201|            .conditional_branch(right_is_true, true_basic_block, false_basic_block);
  529|       |
  530|       |        // Build the true basic block
  531|    201|        self.builder.position_at_end(true_basic_block);
  532|    201|        self.builder.unconditional_branch(end_basic_block);
  533|       |
  534|       |        // Build the false basic block
  535|    201|        self.builder.position_at_end(false_basic_block);
  536|    201|        self.builder.unconditional_branch(end_basic_block);
  537|       |
  538|       |        // Build the end merger basic block
  539|    201|        self.builder.position_at_end(end_basic_block);
  540|       |
  541|       |        // Create a PHI node to merge the results
  542|    201|        let phi = self.builder.phi(self.int32_type(), "lor.phi");
  543|    201|        let true_value = self.const_int(1);
  544|    201|        let false_value = self.const_int(0);
  545|       |
  546|       |        // Add incoming values to the PHI node
  547|    201|        phi.add_incoming(
  548|    201|            &[true_value, false_value],
  549|    201|            &[true_basic_block, false_basic_block],
  550|       |        );
  551|       |
  552|       |        // Append all our new basic blocks to the function
  553|    201|        function.append_existing_basic_block(true_basic_block);
  554|    201|        function.append_existing_basic_block(false_basic_block);
  555|    201|        function.append_existing_basic_block(end_basic_block);
  556|       |
  557|    201|        phi.value()
  558|    201|    }
_RNvMs0_Cs3o0P8Y3fg0l_14rustcc_codegenNtB5_7Codegen25codegen_binary_not_equals:
