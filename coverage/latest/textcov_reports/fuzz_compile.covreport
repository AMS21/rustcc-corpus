  203|       |                // if the current block has a terminator, don't generate anything since it's
  204|       |                // unreachable
  205|       |                // TODO: Warn about unreachable code
  206|    115|                break;
  207|  19.7k|            }
  208|       |
  209|  19.7k|            match statement {
