  202|  26.8k|            if self.builder.has_insert_block_terminator() {
  203|       |                // if the current block has a terminator, don't generate anything since it's
  204|       |                // unreachable
  205|       |                // TODO: Warn about unreachable code
  206|    102|                break;
  207|  26.7k|            }
  208|       |
  209|  26.7k|            match statement {
  210|  22.8k|                BlockItem::Statement(statement) => self.codegen_statement(statement),
  211|  3.94k|                BlockItem::Declaration(declaration) => {
  212|  3.94k|                    self.codegen_declaration(declaration);
  213|  3.94k|                }
  214|       |            }
  215|       |        }
  216|       |
  217|       |        // Check if the last block has a terminator
  218|       |        #[expect(clippy::expect_used)]
  219|  3.96k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  3.96k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  3.83k|            if function.name == "main" {
  224|    213|                // If main is missing a terminator add return 0
  225|    213|                let zero = self.const_int(0);
  226|    213|                self.builder.ret(zero);
  227|  3.62k|            } else {
  228|  3.62k|                // For all other functions add unreachable
  229|  3.62k|                self.builder.unreachable();
  230|  3.62k|            }
  231|    127|        }
  232|       |
  233|       |        // Verify generated function and when fuzzing abort on failure
  234|       |        #[cfg(not(fuzzing))]
  235|       |        if !verify_function(
  236|       |            llvm_function,
  237|       |            LLVMVerifierFailureAction::LLVMPrintMessageAction,
  238|       |        ) {
  239|       |            println!("Function verification failed");
  240|       |            return false;
  241|       |        }
  242|       |        #[cfg(fuzzing)]
  243|  3.96k|        let _ = verify_function(
  244|  3.96k|            llvm_function,
  245|  3.96k|            LLVMVerifierFailureAction::LLVMAbortProcessAction,
  246|  3.96k|        );
  247|       |
  248|  3.96k|        true
  249|  3.96k|    }
