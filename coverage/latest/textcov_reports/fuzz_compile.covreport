  562|       |        // The left-hand side of an assignment must be an l-value.
  563|  4.74k|        let Some(name) = left.as_variable_name() else {
  564|      0|            panic!("left-hand side of assignment must be an l-value");
  565|       |        };
  566|       |
  567|       |        // Store the right-hand side value into the existing variable
  568|  4.74k|        self.store_variable(name, right_value);
  569|       |
  570|       |        // The value of an assignment expression is the value that was assigned, so
  571|       |        // return the codegened right value
  572|  4.74k|        right_value
  573|  4.74k|    }
