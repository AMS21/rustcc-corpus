  772|    172|    fn codegen_unary_prefix_decrement(&self, expression: &Expression) -> LLVMValue {
  773|       |        // The operand of a prefix decrement must be an l-value.
  774|    172|        let Some(name) = expression.as_variable_name() else {
  775|      0|            panic!("operand of prefix decrement must be an l-value");
  776|       |        };
  777|       |
  778|       |        // First load the current value of the variable
  779|    172|        let current_value = self.load_variable(name);
  780|       |
  781|       |        // Then subtract 1 from it
  782|    172|        let one = self.const_int(1);
