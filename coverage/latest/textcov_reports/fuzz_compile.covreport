  211|  2.31k|                BlockItem::Declaration(declaration) => {
  212|  2.31k|                    self.codegen_declaration(declaration);
  213|  2.31k|                }
  214|       |            }
  215|       |        }
  216|       |
  217|       |        // Check if the last block has a terminator
  218|       |        #[expect(clippy::expect_used)]
  219|  3.46k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  3.46k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  3.31k|            if function.name == "main" {
  224|    334|                // If main is missing a terminator add return 0
  225|    334|                let zero = self.const_int(0);
  226|    334|                self.builder.ret(zero);
  227|  2.98k|            } else {
