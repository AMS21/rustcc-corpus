  220|       |
  221|  3.64k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  3.48k|            if function.name == "main" {
  224|    365|                // If main is missing a terminator add return 0
  225|    365|                let zero = self.const_int(0);
  226|    365|                self.builder.ret(zero);
  227|  3.12k|            } else {
