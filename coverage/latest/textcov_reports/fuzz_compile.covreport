  561|  6.16k|    fn codegen_binary_assignment(&self, left: &Expression, right_value: LLVMValue) -> LLVMValue {
  562|       |        // The left-hand side of an assignment must be an l-value.
  563|  6.16k|        let Some(name) = left.as_variable_name() else {
