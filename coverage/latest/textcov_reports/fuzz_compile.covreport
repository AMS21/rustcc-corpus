  471|       |
  472|       |        // Build the end merger basic block
  473|  21.3k|        self.builder.position_at_end(end_basic_block);
  474|       |
  475|       |        // Create a PHI node to merge the results
  476|  21.3k|        let phi = self.builder.phi(self.int32_type(), "land.phi");
  477|  21.3k|        let true_value = self.const_int(1);
  478|  21.3k|        let false_value = self.const_int(0);
  479|       |
  480|       |        // Add incoming values to the PHI node
