_RNvMs0_Cs3o0P8Y3fg0l_14rustcc_codegenNtB5_7Codegen16codegen_function:
  186|  2.54k|    fn codegen_function(&self, function: &FunctionDefinition) -> bool {
  187|       |        // Clear the symbol table for the new function scope
  188|  2.54k|        self.symbol_table.borrow_mut().clear();
  189|       |
  190|       |        // Create the function type
  191|  2.54k|        let function_type = function_type(self.int32_type());
  192|       |
  193|       |        // Create the function
  194|  2.54k|        let llvm_function = self.function(&function.name, function_type);
  195|       |
  196|       |        // Create a basic block in the function and set our builder to generate
  197|       |        // code in it.
  198|  2.54k|        self.function_basic_block("entry", llvm_function);
  199|       |
  200|       |        // Codegen the function body
  201|  24.7k|        for statement in &function.body {
  202|  22.3k|            if self.builder.has_insert_block_terminator() {
  203|       |                // if the current block has a terminator, don't generate anything since it's
  204|       |                // unreachable
  205|       |                // TODO: Warn about unreachable code
  206|    133|                break;
  207|  22.1k|            }
  208|       |
  209|  22.1k|            match statement {
  210|  19.8k|                BlockItem::Statement(statement) => self.codegen_statement(statement),
  211|  2.30k|                BlockItem::Declaration(declaration) => {
  212|  2.30k|                    self.codegen_declaration(declaration);
  213|  2.30k|                }
  214|       |            }
  215|       |        }
  216|       |
  217|       |        // Check if the last block has a terminator
  218|       |        #[expect(clippy::expect_used)]
  219|  2.54k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  2.54k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  2.39k|            if function.name == "main" {
  224|     72|                // If main is missing a terminator add return 0
  225|     72|                let zero = self.const_int(0);
  226|     72|                self.builder.ret(zero);
  227|  2.31k|            } else {
  228|  2.31k|                // For all other functions add unreachable
  229|  2.31k|                self.builder.unreachable();
  230|  2.31k|            }
  231|    150|        }
  232|       |
  233|       |        // Verify generated function and when fuzzing abort on failure
  234|       |        #[cfg(not(fuzzing))]
  235|       |        if !verify_function(
  236|       |            llvm_function,
  237|       |            LLVMVerifierFailureAction::LLVMPrintMessageAction,
  238|       |        ) {
  239|       |            println!("Function verification failed");
  240|       |            return false;
  241|       |        }
  242|       |        #[cfg(fuzzing)]
  243|  2.54k|        let _ = verify_function(
  244|  2.54k|            llvm_function,
  245|  2.54k|            LLVMVerifierFailureAction::LLVMAbortProcessAction,
  246|  2.54k|        );
  247|       |
  248|  2.54k|        true
  249|  2.54k|    }
