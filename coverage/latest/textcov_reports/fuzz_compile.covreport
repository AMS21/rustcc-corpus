  186|      1|    fn codegen_function(&self, function: &FunctionDefinition) -> bool {
  187|       |        // Clear the symbol table for the new function scope
  188|      1|        self.symbol_table.borrow_mut().clear();
  189|       |
  190|       |        // Create the function type
  191|      1|        let function_type = function_type(self.int32_type());
  192|       |
  193|       |        // Create the function
  194|      1|        let llvm_function = self.function(&function.name, function_type);
  195|       |
  196|       |        // Create a basic block in the function and set our builder to generate
  197|       |        // code in it.
  198|      1|        self.function_basic_block("entry", llvm_function);
  199|       |
  200|       |        // Codegen the function body
  201|      1|        for statement in &function.body {
  202|      0|            if self.builder.has_insert_block_terminator() {
  203|       |                // if the current block has a terminator, don't generate anything since it's
  204|       |                // unreachable
  205|       |                // TODO: Warn about unreachable code
  206|      0|                break;
  207|      0|            }
  208|       |
  209|      0|            match statement {
  210|      0|                BlockItem::Statement(statement) => self.codegen_statement(statement),
  211|      0|                BlockItem::Declaration(declaration) => {
  212|      0|                    self.codegen_declaration(declaration);
  213|      0|                }
  214|       |            }
  215|       |        }
  216|       |
  217|       |        // Check if the last block has a terminator
