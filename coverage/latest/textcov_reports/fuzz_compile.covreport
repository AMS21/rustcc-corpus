  772|    427|    fn codegen_unary_prefix_decrement(&self, expression: &Expression) -> LLVMValue {
  773|       |        // The operand of a prefix decrement must be an l-value.
  774|    427|        let Some(name) = expression.as_variable_name() else {
  775|      0|            panic!("operand of prefix decrement must be an l-value");
  776|       |        };
