  186|  2.68k|    fn codegen_function(&self, function: &FunctionDefinition) -> bool {
  187|       |        // Clear the symbol table for the new function scope
  188|  2.68k|        self.symbol_table.borrow_mut().clear();
  189|       |
  190|       |        // Create the function type
  191|  2.68k|        let function_type = function_type(self.int32_type());
  192|       |
  193|       |        // Create the function
  194|  2.68k|        let llvm_function = self.function(&function.name, function_type);
  195|       |
  196|       |        // Create a basic block in the function and set our builder to generate
  197|       |        // code in it.
  198|  2.68k|        self.function_basic_block("entry", llvm_function);
  199|       |
  200|       |        // Codegen the function body
  201|  19.4k|        for statement in &function.body {
  202|  16.8k|            if self.builder.has_insert_block_terminator() {
  203|       |                // if the current block has a terminator, don't generate anything since it's
  204|       |                // unreachable
  205|       |                // TODO: Warn about unreachable code
  206|    107|                break;
  207|  16.7k|            }
  208|       |
  209|  16.7k|            match statement {
  210|  13.9k|                BlockItem::Statement(statement) => self.codegen_statement(statement),
  211|  2.82k|                BlockItem::Declaration(declaration) => {
  212|  2.82k|                    self.codegen_declaration(declaration);
  213|  2.82k|                }
  214|       |            }
  215|       |        }
  216|       |
  217|       |        // Check if the last block has a terminator
  218|       |        #[expect(clippy::expect_used)]
  219|  2.68k|        let basic_block = self.builder.get_insert_block().expect("No insert block");
  220|       |
  221|  2.68k|        if basic_block.terminator().is_none() {
  222|       |            // TODO: What about void function
  223|  2.55k|            if function.name == "main" {
  224|    187|                // If main is missing a terminator add return 0
  225|    187|                let zero = self.const_int(0);
  226|    187|                self.builder.ret(zero);
  227|  2.37k|            } else {
  228|  2.37k|                // For all other functions add unreachable
  229|  2.37k|                self.builder.unreachable();
  230|  2.37k|            }
  231|    125|        }
  232|       |
  233|       |        // Verify generated function and when fuzzing abort on failure
  234|       |        #[cfg(not(fuzzing))]
  235|       |        if !verify_function(
  236|       |            llvm_function,
  237|       |            LLVMVerifierFailureAction::LLVMPrintMessageAction,
  238|       |        ) {
  239|       |            println!("Function verification failed");
  240|       |            return false;
  241|       |        }
  242|       |        #[cfg(fuzzing)]
  243|  2.68k|        let _ = verify_function(
  244|  2.68k|            llvm_function,
  245|  2.68k|            LLVMVerifierFailureAction::LLVMAbortProcessAction,
  246|  2.68k|        );
  247|       |
  248|  2.68k|        true
  249|  2.68k|    }
