  229|  2.60k|                self.builder.unreachable();
  230|  2.60k|            }
  231|     94|        }
  232|       |
  233|       |        // Verify generated function and when fuzzing abort on failure
  234|       |        #[cfg(not(fuzzing))]
  235|       |        if !verify_function(
  236|       |            llvm_function,
  237|       |            LLVMVerifierFailureAction::LLVMPrintMessageAction,
  238|       |        ) {
  239|       |            println!("Function verification failed");
  240|       |            return false;
  241|       |        }
  242|       |        #[cfg(fuzzing)]
  243|  2.90k|        let _ = verify_function(
  244|  2.90k|            llvm_function,
  245|  2.90k|            LLVMVerifierFailureAction::LLVMAbortProcessAction,
