_RNvMs0_Csa3tq7LJwGU2_14rustcc_codegenNtB5_7Codegen30codegen_unary_prefix_increment:
  751|    162|    fn codegen_unary_prefix_increment(&self, expression: &Expression) -> LLVMValue {
  752|       |        // The operand of a prefix increment must be an l-value.
  753|    162|        let Some(name) = expression.as_variable_name() else {
  754|      0|            panic!("operand of prefix increment must be an l-value");
  755|       |        };
  756|       |
  757|       |        // First load the current value of the variable
  758|    162|        let current_value = self.load_variable(name);
  759|       |
  760|       |        // Then add 1 to it
  761|    162|        let one = self.const_int(1);
  762|    162|        let new_value = self.builder.add(current_value, one);
