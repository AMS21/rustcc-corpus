  234|       |        #[cfg(not(fuzzing))]
  235|       |        if !verify_function(
  236|       |            llvm_function,
  237|       |            LLVMVerifierFailureAction::LLVMPrintMessageAction,
  238|       |        ) {
  239|       |            println!("Function verification failed");
  240|       |            return false;
  241|       |        }
  242|       |        #[cfg(fuzzing)]
  243|  4.27k|        let _ = verify_function(
  244|  4.27k|            llvm_function,
  245|  4.27k|            LLVMVerifierFailureAction::LLVMAbortProcessAction,
