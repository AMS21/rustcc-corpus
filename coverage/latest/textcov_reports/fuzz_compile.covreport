  229|  2.98k|                self.builder.unreachable();
  230|  2.98k|            }
  231|    146|        }
  232|       |
  233|       |        // Verify generated function and when fuzzing abort on failure
  234|       |        #[cfg(not(fuzzing))]
  235|       |        if !verify_function(
  236|       |            llvm_function,
  237|       |            LLVMVerifierFailureAction::LLVMPrintMessageAction,
  238|       |        ) {
  239|       |            println!("Function verification failed");
  240|       |            return false;
  241|       |        }
  242|       |        #[cfg(fuzzing)]
  243|  3.46k|        let _ = verify_function(
  244|  3.46k|            llvm_function,
  245|  3.46k|            LLVMVerifierFailureAction::LLVMAbortProcessAction,
  246|  3.46k|        );
  247|       |
  248|  3.46k|        true
  249|  3.46k|    }
